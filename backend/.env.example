# Cấu hình Environment Variables cho Backend

# ============ FLASK ============
FLASK_ENV=development
DEBUG=True

# ============ SERIAL PORT ============
COM_PORT=COM2
BAUD_RATE=9600

# ============ DATABASE ============
DATABASE_TYPE=sqlite
# Nếu dùng MySQL:
# DATABASE_TYPE=mysql
# DB_USER=root
# DB_PASSWORD=password
# DB_HOST=localhost
# DB_NAME=alcohol_detector

# ============ LOGGING ============
LOG_LEVEL=INFO
LOG_FILE=./logs/app.log
